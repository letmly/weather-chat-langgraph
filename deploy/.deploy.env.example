# Скопируй в deploy/.deploy.env и впиши значения. Файл .deploy.env в .gitignore.
SSH_USER=deployuser
SSH_HOST=your.server.ip
SSH_PORT=22
SSH_KEY=~/.ssh/your-private-key
REMOTE_DIR=/home/deployuser/weather-chat
DOMAIN=weatherchat.example.com
REPO_URL=https://github.com/<you>/weather-chat-langgraph.git
# опционально:
# SERVICE_NAME=weatherchat
# CONTAINER_NAME=weatherchat
# CONTAINER_PORT=80
